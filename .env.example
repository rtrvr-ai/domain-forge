# Copy to `.env` and fill in whichever provider you want to use.
# DomainForge auto-detects the first key present (preference: Claude, OpenAI,
# Gemini, OpenRouter). You only need ONE. With none set, the tool still runs
# fully (pure-algorithmic) — you just lose LLM seed-gen and the curated shortlist.

# ── Claude (recommended) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Default model: claude-opus-4-8 (override only if you know what you want)
# ANTHROPIC_MODEL is not used; set --model or config "model" to override.

# ── OpenAI ────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Default model is best-effort; set to your account's latest if it 404s:
OPENAI_MODEL=gpt-5.1

# ── OpenRouter (great for open-source models) ─────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.1

# ── Google Gemini ─────────────────────────────────────────────────────
GEMINI_API_KEY=
# (GOOGLE_API_KEY also works)
GEMINI_MODEL=gemini-2.5-pro
